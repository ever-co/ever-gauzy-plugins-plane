{
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@ever-gauzy/plugin-integration-plane-api": ["packages/plugin-plane/src"],
      "@ever-gauzy/plugin-integration-plane-models": ["packages/models/src"]
    },
    "outDir": "./dist",
    "module": "commonjs",
    "target": "es2017",
    "lib": ["es2020", "dom", "es2018", "esnext.array"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "typeRoots": ["node_modules/@types"],
    "preserveConstEnums": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": false,
    "noImplicitAny": false,
    "useDefineForClassFields": false
  },
  "include": ["packages/**/*", "apps/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.e2e-spec.ts", "**/test/**"]
}
