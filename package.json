{
  "name": "ever-plane",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start:api:dev": "yarn --cwd ./apps/api-plane start",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "latest",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}