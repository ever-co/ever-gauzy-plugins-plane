# ── Plane-on-Kubernetes deployment config ─────────────────────────────────────
# Copy to `.env` and fill in. Consumed by build-images.sh and deploy.sh.
# NEVER commit a filled-in .env. No Gauzy apiKey/apiSecret belong here — those
# live server-side in Gauzy; the Plane UIs only need the public API URL + tenant.

# ── Gauzy backend ─────────────────────────────────────────────────────────────
GAUZY_API_URL=https://api.gauzy.co          # self-hosted: https://api.your-co.com
TENANT_ID=00000000-0000-0000-0000-000000000000   # your Gauzy tenant UUID (baked into the build)

# Derived (do not edit): the value baked into every Plane front-end as VITE_API_BASE_URL
# VITE_API_BASE_URL = ${GAUZY_API_URL}/api/plane/${TENANT_ID}

# ── Build / registry ──────────────────────────────────────────────────────────
PLANE_SRC=../../../plane                     # path to your Plane source checkout
IMAGE_REGISTRY=registry.digitalocean.com/ever
IMAGE_TAG=tenant-acme-1                       # per-tenant + version; keep it immutable
DOCKER_BUILDKIT=1

# ── Topology ──────────────────────────────────────────────────────────────────
TOPOLOGY=single                              # single | subdomains
PLANE_HOST=plane.gauzy.co                     # web host (and path-routed apps in `single`)
PLANE_ADMIN_HOST=plane-admin.gauzy.co         # used only when TOPOLOGY=subdomains
PLANE_SPACE_HOST=plane-space.gauzy.co
PLANE_LIVE_HOST=plane-live.gauzy.co

# ── What to deploy ────────────────────────────────────────────────────────────
DEPLOY_ADMIN=false                            # Plane "God Mode" instance-admin UI
DEPLOY_LIVE=false                             # realtime collab server (requires Redis)
LIVE_SERVER_SECRET_KEY=                       # required iff DEPLOY_LIVE=true

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBE_CONTEXT=do-sfo2-k8s-gauzy
PLANE_NAMESPACE=plane
INGRESS_CLASS=nginx
REPLICAS=2

# TLS: leave CERT_MANAGER_ISSUER empty to use a pre-created `<host>-tls` secret
# (house pattern). Set it (e.g. letsencrypt-prod) to let cert-manager provision certs.
CERT_MANAGER_ISSUER=
TLS_SECRET_WEB=plane.gauzy.co-tls
TLS_SECRET_ADMIN=plane-admin.gauzy.co-tls
TLS_SECRET_SPACE=plane-space.gauzy.co-tls

# Resource requests (house convention: requests always; memory limit on heavier pods)
CPU_REQUEST=50m
MEM_REQUEST=128Mi
